# =============================================================================
# Radiobox - example environment configuration
# Copy this file to `.env` and adjust the values for your station.
# This file is mounted into the liquidsoap and radiobox containers via
# docker-compose's `env_file: .env`, so every variable below is available
# both to Node.js code and to the liquidsoap scripts (see liquidsoap/var.liq).
# =============================================================================

# -----------------------------------------------------------------------------
# Station identity (used by metadata, schedule exporter and liquidsoap)
# -----------------------------------------------------------------------------
STATION_NAME="My Radio Station"

# Claim line shown in "now playing" metadata (prefix in front of the title).
META_STATION_CLAIM="Radio XYZ | Your Community Radio | Now playing: "
# Interval in milliseconds at which metadata is refreshed.
META_UPDATE_INTERVAL=10000

# -----------------------------------------------------------------------------
# Schedule / locale
# -----------------------------------------------------------------------------
# Locale used for schedule rendering (de, en, ...).
SCHEDULE_LOCALE="de"
# IANA time zone used by the scheduler.
SCHEDULE_ZONE="Europe/Berlin"

# Base directory of the radiobox app inside the container.
RADIOBOX_BASEDIR="/app"
# For local development you can point this to your checkout instead:
#RADIOBOX_BASEDIR="/home/youruser/Desktop/radiobox/"

# Broadcast schema (XLSX) describing the weekly programme.
BROADCAST_SCHEMA_FILE="schema/example.xlsx"
# Recording filename prefix / suffix and the folder where MP3s end up.
FILENAME_PREFIX="example-stream"
FILENAME_SUFFIX=".flac"
MP3_PATH="mp3/"

# -----------------------------------------------------------------------------
# Autopilot toggles
# -----------------------------------------------------------------------------
AUTOPILOT_UPLOAD_NEXTCLOUD=true
AUTOPILOT_UPLOAD_WELOCAL=true
# Comma-separated weekdays (1=Mon ... 7=Sun) on which to publish the schema to
# FTP. Leave empty to disable scheduled publishing.
AUTOPILOT_PUT_SCHEMA_DAYS="1, 3, 5, 6"
AUTOPILOT_COPY_REPEAT=true
AUTOPILOT_CLEAN_REPEATS=true

# -----------------------------------------------------------------------------
# Recorder (captures the live stream into the archive)
# -----------------------------------------------------------------------------
RECORDER_STREAM_URL="http://snd.example.net:8000/stream"
# if recording from capture service, you need to install the
# scripts/ffmeg-capture.service:
# RECORDER_STREAM_URL="http://icecast2:8000/lossless-capture"
# Delay in seconds before the recorder actually starts grabbing.
RECORDER_STREAM_DELAY=0
# Daily start time HHMMSS (local time).
RECORDER_START_TIME="140000"
# Recording duration in hours.
RECORDER_DURATION=12
# Bitrate in kbps for the recorded stream.
RECORDER_BITRATE=256

# -----------------------------------------------------------------------------
# Icecast (streaming server)
# -----------------------------------------------------------------------------
ICECAST_PASSWORD=xxx
ICECAST_ADMIN_PASSWORD=hackme
# Public hostname advertised by icecast.
ICECAST_HOSTNAME=localhost
# Hostname/port reachable by liquidsoap inside the docker network.
ICECAST_HOST=icecast2
ICECAST_PORT=8000

# -----------------------------------------------------------------------------
# Liquidsoap: station identity / descriptions
# (STATION_NAME is reused from above.)
# -----------------------------------------------------------------------------
STATION_DESCRIPTION="My Station Description"
STATION_GENRE="freestyle"
STATION_HOST="snd.example.net"

# -----------------------------------------------------------------------------
# Liquidsoap: harbor (DJ live input)
# -----------------------------------------------------------------------------
HARBOR_PORT=4444
HARBOR_USER="harbor_user"
HARBOR_PASSWORD="xxx"

# -----------------------------------------------------------------------------
# Liquidsoap: sources / mounts
# -----------------------------------------------------------------------------
# Upstream stream that liquidsoap relays as the "live" source.
MAIN_STREAM_URL="http://stream.example.net/live"
# Legacy icecast mount name (kept for backwards-compatible listener URLs).
RADIO_LEGACY_MOUNT="Radio"

# -----------------------------------------------------------------------------
# Liquidsoap: behaviour flags
# Presets (set in `.env` to switch behaviour without touching any .liq file):
#   light        -> LIQ_ENABLE_HARBOR=false LIQ_ENABLE_REPEAT_SCHEDULE=false
#   light-repeat -> LIQ_ENABLE_HARBOR=true  LIQ_ENABLE_REPEAT_SCHEDULE=true
#   repeat-only  -> LIQ_ENABLE_HARBOR=false LIQ_LIVE_SOURCE_KIND=silence
#                   LIQ_ENABLE_REPEAT_CROSSFADE=true
#                   disable mp3 mounts, enable LIQ_ENABLE_MOUNT_LOSSLESS
# -----------------------------------------------------------------------------
# Free-form label printed in liquidsoap logs to identify the running config.
LIQ_SCRIPT_LABEL="light-repeat"

# Source-graph flags
LIQ_ENABLE_HARBOR=true
LIQ_ENABLE_REPEAT_SCHEDULE=true
LIQ_ENABLE_REPEAT_CROSSFADE=false
# Where the "live" branch of the schedule pulls audio from:
#   main_stream -> relay MAIN_STREAM_URL
#   harbor      -> use the local harbor input directly
#   silence     -> emit silence (useful for repeat-only setups)
LIQ_LIVE_SOURCE_KIND="main_stream"

# Icecast mounts (each guarded individually, see liquidsoap/mounts.liq)
LIQ_ENABLE_MOUNT_LIVE=true
LIQ_ENABLE_MOUNT_LIVE_128K=true
LIQ_ENABLE_MOUNT_LEGACY=true
LIQ_ENABLE_MOUNT_LOSSLESS=false

# -----------------------------------------------------------------------------
# WeLocal CMMS API
# -----------------------------------------------------------------------------
WELOCAL_API_TOKEN=XXXXX
WELOCAL_API_URL="https://example.welocal.cloud/cmms-api/v3.0"

# -----------------------------------------------------------------------------
# Repeat / schedule labels (German defaults shown)
# -----------------------------------------------------------------------------
REPEAT_SHORT="(Rep.)"
REPEAT_LONG="Repeat from yesterday"
REPEAT_DATE_FORMAT="dd.MM. HH:ss"

SCHEDULE_INFO_EACH="Jeden"
SCHEDULE_INFO_LAST="letzten"
SCHEDULE_INFO_AND="und"
SCHEDULE_INFO_MONTHLY="im Monat"
SCHEDULE_INFO_ALWAYS="Immer"
SCHEDULE_INFO_FROM="ab"
SCHEDULE_INFO_HOUR="Uhr"
SCHEDULE_INFO_HOURS="Stunden"

# -----------------------------------------------------------------------------
# Schedule exporter (writes m3u/metadata files consumed by liquidsoap)
# -----------------------------------------------------------------------------
EXPORTER_FILENAME_PREFIX="program_mystation"
EXPORTER_MP3_PATH="/tmp/liquidsoap/mp3/"
EXPORTER_BASE_PATH="/tmp/liquidsoap/"
EXPORTER_REPEAT_FOLDER="repeat/"

# -----------------------------------------------------------------------------
# FTP (used to publish the weekly schema)
# -----------------------------------------------------------------------------
FTP_HOST="XXX"
FTP_USER="XXX"
FTP_PASSWORD="XXX"
FTP_REMOTE_PATH="program-metadata"
FTP_SECURE=false

# -----------------------------------------------------------------------------
# Nextcloud (WebDAV) - used to upload recordings and fetch the schema
# -----------------------------------------------------------------------------
NEXTCLOUD_WEBDAV_PASSWORD="xxxxx"
NEXTCLOUD_WEBDAV_USER="nc_user"
NEXTCLOUD_WEBDAV_URL="https://cloud.my-station.net"
NEXTCLOUD_WEBDAV_DIRECTORY="Remote Folder"
NEXTCLOUD_WEBDAV_SCHEMA_DIRECTORY="Remote Programmschema Folder"
NEXTCLOUD_WEBDAV_SCHEMA_FILE="example.xlsx"

NEXTCLOUD_WEBDAV_PLAYOUT_DIRECTORY="Studiobox"
